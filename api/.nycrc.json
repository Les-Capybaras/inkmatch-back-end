{
    "all": true,
    "check-coverage": true,
    "include": [
        "src/**/*.js"
    ],
    "exclude": [
        "src/**/*.spec.ts"
    ],
    "reporter": ["text"],
    "report-dir": "coverage",
    "temp-dir": "coverage/.nyc_output",
    "lines": 60,
    "functions": 60,
    "statements": 60
}